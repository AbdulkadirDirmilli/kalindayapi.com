generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  hashedPassword String
  name           String?
  role           String    @default("admin")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLogin      DateTime?
}

model Ilan {
  id                  String            @id @default(uuid())
  baslik              String
  slug                String            @unique
  kategori            String
  tip                 String
  altTip              String?
  fiyat               Int
  paraBirimi          String            @default("TL")
  il                  String
  ilce                String
  mahalle             String?
  koordinatLat        Float?
  koordinatLng        Float?
  brutMetrekare       Int?
  netMetrekare        Int?
  metrekare           Int?
  odaSayisi           String?
  banyoSayisi         Int?
  tuvaletSayisi       Int?
  balkonSayisi        Int?
  kat                 Int?
  toplamKat           Int?
  binaYasi            Int?
  binaTipi            String?
  kullanimDurumu      String?
  insaatDurumu        String?
  isitma              String?
  yakitTipi           String?
  enerjiSinifi        String?
  esyali              Boolean           @default(false)
  balkon              Boolean           @default(false)
  asansor             Boolean           @default(false)
  otopark             Boolean           @default(false)
  guvenlik            Boolean           @default(false)
  havuz               Boolean           @default(false)
  bahce               Boolean           @default(false)
  bahceMetrekare      Int?
  icOzellikler        String?
  disOzellikler       String?
  muhitOzellikleri    String?
  guvenlikOzellikleri String?
  cephe               String?
  manzara             String?
  imarDurumu          String?
  emsal               String?
  gabari              String?
  taks                Float?
  kaks                Float?
  yolCephesi          Int?
  derinlik            Int?
  arsaTipi            String?
  egim                String?
  zemin               String?
  altyapi             Boolean           @default(false)
  altyapiDetay        String?
  tarimOzellikleri    String?
  adaNo               String?
  parselNo            String?
  paftaNo             String?
  ticariTip           String?
  cepheGenisligi      Int?
  tavanYuksekligi     Float?
  personelKapasitesi  Int?
  depoOzellikleri     String?
  tapuDurumu          String?
  krediyeUygun        Boolean           @default(false)
  takasaUygun         Boolean           @default(false)
  isyeriRuhsati       Boolean           @default(false)
  eidsStatus          String            @default("pending")
  videoUrl            String?
  danismanId          String?
  aciklama            String
  oneCikan            Boolean           @default(false)
  durum               String            @default("aktif")
  ilanNo              String?           @unique
  yayinTarihi         DateTime          @default(now())
  guncellenmeTarihi   DateTime          @updatedAt
  createdAt           DateTime          @default(now())
  viewCount           Int               @default(0)
  danisman            Ortak?            @relation(fields: [danismanId], references: [id])
  fotograflar         IlanFoto[]
  translations        IlanTranslation[]
  views               IlanView[]
}

model IlanFoto {
  id        String   @id @default(uuid())
  ilanId    String
  url       String
  sira      Int      @default(0)
  createdAt DateTime @default(now())
  ilan      Ilan     @relation(fields: [ilanId], references: [id], onDelete: Cascade)

  @@index([ilanId])
}

model IlanView {
  id        String   @id @default(uuid())
  ilanId    String
  visitorId String
  viewedAt  DateTime @default(now())
  ilan      Ilan     @relation(fields: [ilanId], references: [id], onDelete: Cascade)

  @@unique([ilanId, visitorId])
  @@index([ilanId])
}

model Hizmet {
  id           String              @id @default(uuid())
  slug         String              @unique
  baslik       String
  kisaAciklama String
  uzunAciklama String
  ikon         String
  sira         Int                 @default(0)
  aktif        Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  altHizmetler AltHizmet[]
  bolgeler     HizmetBolge[]
  sss          HizmetSSS[]
  translations HizmetTranslation[]
}

model AltHizmet {
  id        String   @id @default(uuid())
  hizmetId  String
  baslik    String
  aciklama  String
  ikon      String
  sira      Int      @default(0)
  createdAt DateTime @default(now())
  hizmet    Hizmet   @relation(fields: [hizmetId], references: [id], onDelete: Cascade)
}

model HizmetSSS {
  id        String   @id @default(uuid())
  hizmetId  String
  soru      String
  cevap     String
  sira      Int      @default(0)
  createdAt DateTime @default(now())
  hizmet    Hizmet   @relation(fields: [hizmetId], references: [id], onDelete: Cascade)
}

model HizmetBolge {
  id       String @id @default(uuid())
  hizmetId String
  bolge    String
  hizmet   Hizmet @relation(fields: [hizmetId], references: [id], onDelete: Cascade)

  @@unique([hizmetId, bolge])
}

model ContactForm {
  id        String   @id @default(uuid())
  ad        String
  email     String
  telefon   String?
  konu      String?
  mesaj     String
  durum     String   @default("yeni")
  notlar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  thumbnailUrl String?
  kategori     String?
  altText      String?
  createdAt    DateTime @default(now())
}

model Ortak {
  id               String   @id @default(uuid())
  slug             String   @unique
  ad               String
  unvan            String
  telefon          String
  whatsapp         String?
  email            String?
  biyografi        String?
  foto             String?
  uzmanlikAlanlari String
  sira             Int      @default(0)
  aktif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  ilanlar          Ilan[]
}

model SiteSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OncesiSonrasi {
  id          String   @id @default(uuid())
  baslik      String
  kategori    String?
  konum       String?
  oncesiFoto  String
  sonrasiFoto String
  sira        Int      @default(0)
  aktif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  phone        String
  listingId    String
  listingTitle String
  createdAt    DateTime @default(now())

  @@unique([phone, listingId])
  @@index([listingId])
  @@index([createdAt])
}

model SmsGroup {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  contacts  SmsContact[]
}

model SmsContact {
  id        String    @id @default(uuid())
  name      String
  phone     String
  note      String?
  groupId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  group     SmsGroup? @relation(fields: [groupId], references: [id])

  @@index([phone])
  @@index([groupId])
}

model SmsTemplate {
  id        String   @id @default(uuid())
  title     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmsLog {
  id           String   @id @default(uuid())
  message      String
  senderName   String
  recipients   String
  totalSent    Int
  successCount Int      @default(0)
  failedCount  Int      @default(0)
  status       String   @default("pending")
  errorMessage String?
  netgsmJobId  String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model SmsSettings {
  id             String   @id @default(uuid())
  netgsmUsername String
  netgsmPassword String
  netgsmHeader   String
  senderNames    String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Language {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  nativeName String
  direction  String   @default("ltr")
  aktif      Boolean  @default(true)
  sira       Int      @default(0)
  createdAt  DateTime @default(now())
}

model IlanTranslation {
  id             String   @id @default(uuid())
  ilanId         String
  language       String   @default("tr")
  baslik         String
  slug           String
  aciklama       String
  kategori       String?
  tip            String?
  seoTitle       String?
  seoDescription String?
  status         String   @default("draft")
  translatedBy   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ilan           Ilan     @relation(fields: [ilanId], references: [id], onDelete: Cascade)

  @@unique([ilanId, language])
  @@unique([slug, language])
  @@index([language])
}

model HizmetTranslation {
  id             String   @id @default(uuid())
  hizmetId       String
  language       String   @default("tr")
  baslik         String
  slug           String
  kisaAciklama   String
  uzunAciklama   String
  seoTitle       String?
  seoDescription String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  hizmet         Hizmet   @relation(fields: [hizmetId], references: [id], onDelete: Cascade)

  @@unique([hizmetId, language])
  @@unique([slug, language])
  @@index([language])
}

model BlogPost {
  id                String                @id @default(uuid())
  originalSlug      String                @unique
  kategori          String
  yazar             String
  kapakGorsel       String?
  yayinTarihi       DateTime              @default(now())
  guncellenmeTarihi DateTime              @updatedAt
  aktif             Boolean               @default(true)
  translations      BlogPostTranslation[]
}

model BlogPostTranslation {
  id             String   @id @default(uuid())
  postId         String
  language       String   @default("tr")
  baslik         String
  slug           String
  ozet           String
  icerik         String
  etiketler      String
  seoTitle       String?
  seoDescription String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  post           BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, language])
  @@unique([slug, language])
  @@index([language])
}

model SiteVisit {
  id          String   @id @default(uuid())
  visitorHash String
  userAgent   String?
  path        String?
  referrer    String?
  country     String?
  visitedAt   DateTime @default(now())

  @@index([visitedAt])
  @@index([visitorHash, visitedAt])
}

model SiteStats {
  id             String   @id @default(uuid())
  date           DateTime @unique
  totalVisits    Int      @default(0)
  uniqueVisitors Int      @default(0)
  pageViews      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}
